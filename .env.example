# Copy this file to .env and fill in values
# cp .env.example .env

# ── Chaos mode (set to true to simulate failures) ─────────────────────────────
CHAOS_USER=false
CHAOS_ORDER=false
CHAOS_PAYMENT=false
CHAOS_INVENTORY=false
CHAOS_NOTIFICATION=false

# ── Slack (optional — for escalation alerts) ──────────────────────────────────
SLACK_WEBHOOK_URL=

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_NAME=neuralops-lstm-autoencoder
MODEL_STAGE=Production

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_METRICS_TOPIC=metrics-stream
KAFKA_ALERTS_TOPIC=anomaly-alerts

# ── Drift detection ───────────────────────────────────────────────────────────
DRIFT_THRESHOLD=0.3
RETRAIN_EPOCHS=30

# ── Kubernetes ────────────────────────────────────────────────────────────────
K8S_NAMESPACE=neuralops
VERIFY_WAIT_SECONDS=300
