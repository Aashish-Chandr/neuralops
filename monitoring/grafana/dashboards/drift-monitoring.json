{
  "title": "NeuralOps — Model Drift & Health",
  "uid": "neuralops-drift",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "Drift Fraction (latest run)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "model_drift_fraction", "legendFormat": "drift" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            {"color":"green","value":0},
            {"color":"yellow","value":0.2},
            {"color":"red","value":0.3}
          ]}
        }
      }
    },
    {
      "id": 2, "type": "stat",
      "title": "Drifted Features",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "model_drift_features_drifted" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":0},{"color":"red","value":2}] }
        }
      }
    },
    {
      "id": 3, "type": "stat",
      "title": "Model Version (Production)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "mlflow_model_version{stage=\"Production\"}" }]
    },
    {
      "id": 4, "type": "stat",
      "title": "Retrains Triggered (30d)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "increase(model_retrains_total[30d])" }]
    },
    {
      "id": 5, "type": "timeseries",
      "title": "Drift Fraction Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "targets": [
        { "expr": "model_drift_fraction", "legendFormat": "drift fraction" },
        { "expr": "0.3", "legendFormat": "retrain threshold" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": [{
          "matcher": { "id": "byName", "options": "retrain threshold" },
          "properties": [
            { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 8] } },
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
          ]
        }]
      }
    },
    {
      "id": 6, "type": "table",
      "title": "Feature Drift Status",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "targets": [{
        "expr": "model_feature_drift_score",
        "legendFormat": "{{feature}}",
        "instant": true
      }],
      "transformations": [{ "id": "sortBy", "options": { "fields": [{"displayName":"Value","desc":true}] } }]
    },
    {
      "id": 7, "type": "timeseries",
      "title": "Production Data Distribution — CPU Usage",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [
        { "expr": "avg(cpu_usage_percent)", "legendFormat": "production avg" },
        { "expr": "20", "legendFormat": "training baseline" }
      ]
    },
    {
      "id": 8, "type": "timeseries",
      "title": "Production Data Distribution — Error Rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "targets": [
        { "expr": "avg(error_rate_percent)", "legendFormat": "production avg" },
        { "expr": "1", "legendFormat": "training baseline" }
      ]
    },
    {
      "id": 9, "type": "logs",
      "title": "Drift Detector Logs",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{app=\"drift-detector\"}" }]
    }
  ]
}
